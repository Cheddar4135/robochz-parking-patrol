<?xml version="1.0"?>
<model>
    <name>robochz_waffle</name>
    <version>1.0</version>
    <sdf version='1.6'>model.sdf</sdf>

    <author>
        <name>robochz</name>
        <email>ewhaailab2026@gmail.com</email>
    </author>

    <description>
        TurtleBot3 Waffle 복사본 (Cheezlbot). turtlebot3_gazebo waffle model.sdf 기반,
        카메라를 우측 90°(yaw -1.5708) 회전 마운트 — 통로 주행 중 측면 번호판 촬영용.
        메시는 model://turtlebot3_common 참조(복사 안 함).
    </description>
</model>
